package-lock.json
yarn.lock
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.yarn-integrity
.pnp.*
.npm

# ============================================
# IDEs and Editors
# ============================================
.idea/
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode-test
# Ignore machine-specific VS Code state, but VERSION the shareable workspace config.
# Use `.vscode/*` (not `.vscode/`) so the negations below can re-include files —
# a dir-level ignore would block re-inclusion entirely.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/*.code-snippets

