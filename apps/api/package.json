{
  "name": "@nest-logger-example/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.cjs",
    "test:cov": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.cjs --coverage",
    "test:e2e": "NODE_OPTIONS='--experimental-vm-modules' jest --config test/jest-e2e.config.cjs",
    "test:int": "NODE_OPTIONS='--experimental-vm-modules' jest --config test/jest-int.config.cjs --runInBand",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@bymax-one/nest-logger": "file:../../../nest-logger",
    "@nestjs/common": "^11",
    "@nestjs/config": "^4",
    "@nestjs/core": "^11",
    "@nestjs/platform-express": "^11",
    "@nestjs/schedule": "^6.1.3",
    "@opentelemetry/api": ">=1.9.0 <1.10",
    "@opentelemetry/auto-instrumentations-node": "^0.76",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218",
    "@opentelemetry/resources": "^2",
    "@opentelemetry/sdk-node": "^0.218",
    "@opentelemetry/semantic-conventions": "^1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "express": "^5",
    "pino": "^10",
    "reflect-metadata": "^0.2",
    "rxjs": "^7.8",
    "zod": "^4"
  },
  "optionalDependencies": {
    "pino-pretty": "^13",
    "pino-roll": "^3"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@nestjs/cli": "^11",
    "@nestjs/testing": "^11.1.24",
    "@types/express": "^5",
    "@types/jest": "^30.0.0",
    "@types/node": "^24",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4"
  }
}
